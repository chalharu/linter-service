{
  "linters": [
    {
      "name": "actionlint",
      "sarif": {
        "enabled": true
      }
    },
    {
      "name": "ghalint",
      "sarif": {
        "enabled": true
      }
    },
    {
      "name": "hadolint",
      "sarif": {
        "enabled": true
      }
    },
    {
      "name": "trivy",
      "sarif": {
        "enabled": true,
        "default_level": "warning"
      }
    },
    {
      "name": "dotenv-linter",
      "sarif": {
        "enabled": true
      }
    },
    {
      "name": "spectral",
      "sarif": {
        "enabled": true
      }
    },
    {
      "name": "yamllint",
      "sarif": {
        "enabled": true
      }
    },
    {
      "name": "yamlfmt",
      "sarif": {
        "enabled": true
      }
    },
    {
      "name": "markdownlint-cli2",
      "sarif": {
        "enabled": true
      }
    },
    {
      "name": "textlint",
      "isolated": true,
      "required_root_files": [
        ".textlintrc"
      ],
      "sarif": {
        "enabled": true
      }
    },
    {
      "name": "ruff",
      "sarif": {
        "enabled": true
      }
    },
    {
      "name": "rustfmt",
      "sarif": {
        "enabled": true
      }
    },
    {
      "name": "cargo-clippy",
      "isolated": true,
      "sarif": {
        "enabled": true
      }
    },
    {
      "name": "cargo-deny",
      "sarif": {
        "enabled": true,
        "target_kind": "cargo-projects"
      }
    },
    {
      "name": "taplo",
      "sarif": {
        "enabled": true
      }
    },
    {
      "name": "biome",
      "sarif": {
        "enabled": true
      }
    },
    {
      "name": "editorconfig-checker",
      "sarif": {
        "enabled": true
      }
    },
    {
      "name": "shellcheck",
      "sarif": {
        "enabled": true
      }
    },
    {
      "name": "zizmor",
      "sarif": {
        "enabled": true
      }
    }
  ]
}
