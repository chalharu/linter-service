{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "automationDetails": {
        "id": "linter-service/textlint"
      },
      "results": [
        {
          "level": "error",
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "README.md"
                },
                "region": {
                  "startColumn": 9,
                  "startLine": 1
                }
              }
            }
          ],
          "message": {
            "text": "Disallow to use \"！\". [Error/ja-technical-writing/no-exclamation-question-mark]"
          },
          "properties": {
            "linter_name": "textlint"
          },
          "ruleId": "textlint/diagnostic"
        }
      ],
      "tool": {
        "driver": {
          "informationUri": "https://github.com/chalharu/linter-service",
          "name": "linter-service/textlint",
          "rules": [
            {
              "id": "textlint/diagnostic",
              "name": "textlint/diagnostic",
              "shortDescription": {
                "text": "textlint/diagnostic"
              }
            }
          ]
        }
      }
    }
  ],
  "version": "2.1.0"
}
