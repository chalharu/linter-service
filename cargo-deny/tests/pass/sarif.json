{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "automationDetails": {
        "id": "linter-service/cargo-deny"
      },
      "results": [
        {
          "level": "warning",
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "Cargo.toml"
                },
                "region": {
                  "startColumn": 1,
                  "startLine": 1
                }
              }
            }
          ],
          "message": {
            "text": "license expression was not specified in manifest for crate 'fixture-pass = 0.1.0'"
          },
          "properties": {
            "linter_name": "cargo-deny"
          },
          "ruleId": "cargo-deny/no-license-field"
        },
        {
          "level": "error",
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "Cargo.toml"
                },
                "region": {
                  "startColumn": 1,
                  "startLine": 1
                }
              }
            }
          ],
          "message": {
            "text": "fixture-pass = 0.1.0 is unlicensed"
          },
          "properties": {
            "linter_name": "cargo-deny"
          },
          "ruleId": "cargo-deny/unlicensed"
        },
        {
          "level": "warning",
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "Cargo.toml"
                },
                "region": {
                  "startColumn": 1,
                  "startLine": 1
                }
              }
            }
          ],
          "message": {
            "text": "a valid license expression could not be retrieved for the crate"
          },
          "properties": {
            "linter_name": "cargo-deny"
          },
          "ruleId": "cargo-deny/unlicensed"
        }
      ],
      "tool": {
        "driver": {
          "informationUri": "https://github.com/chalharu/linter-service",
          "name": "linter-service/cargo-deny",
          "rules": [
            {
              "id": "cargo-deny/no-license-field",
              "name": "cargo-deny/no-license-field",
              "shortDescription": {
                "text": "cargo-deny/no-license-field"
              }
            },
            {
              "id": "cargo-deny/unlicensed",
              "name": "cargo-deny/unlicensed",
              "shortDescription": {
                "text": "cargo-deny/unlicensed"
              }
            }
          ]
        }
      }
    }
  ],
  "version": "2.1.0"
}
